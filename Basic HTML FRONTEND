        <p class="text-lg text-slate-400 max-w-2xl mx-auto">Every transaction follows a trust-first protocol with smart contract escrow and multi-step verification.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Step 1 -->
        <div class="group relative bg-slate-900/60 backdrop-blur-sm border border-white/5 hover:border-brand-500/30 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1">
          <div class="absolute top-4 right-4 text-5xl font-black text-white/[0.03]">01</div>
